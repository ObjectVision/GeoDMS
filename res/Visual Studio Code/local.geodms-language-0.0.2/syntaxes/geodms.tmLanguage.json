|BoundCenter|count_uint8|DefaultUnit|first_point|for_each_ne|lower_bound|mul_or_null|nth_element|regex_match|rnd_uniform|RoundToZero|rth_element|sub_or_null|sum_float32|sum_float64|upper_bound|arc_length|asExprList|asItemList|AsItemName|bg_polygon|BoundRange|bp_polygon|cgal_union|complement|connect_eq|connect_ne|CreateFile|currentDir|district_4|district_8|DomainUnit|dyna_point|for_each_n|geos_union|HtmlDecode|HtmlEncode|isNegative|isPositive|last_point|LowerBound|Mandelbrot|mls_length|RD2LatLong|RoundUp_64|sum_dpoint|sum_ipoint|sum_uint16|sum_uint32|sum_uint64|sum_upoint|trace_back|union_data|union_unit|UpperBound|ValuesUnit|cat_range|DataArray|dist_info|diversity|invertAll|ipf_alloc|IsDefined|LowerCase|max_index|min_index|overlay32|overlay64|parse_xml|perimeter|poly2grid|potential|PropValue|proximity|ramp_open|ReadArray|ReadElems|ReadLines|reg_count|RoundDown|sum_int16|sum_int32|sum_int64|sum_uint8|TiledUnit|UpperCase|UrlDecode|UrlEncode|arc2segm|BaseUnit|bg_union|bp_union|centroid|cgal_xor|classify|CopyFile|cumulate|district|from_utf|Generate|geos_xor|griddist|InitFile|matr_inv|matr_mul|matr_var|max_elem|min_elem|null_i64|null_str|null_u64|point_xy|point_yx|pointcol|pointrow|ramp_rgb|Round_64|strcount|strlen64|subindex|sum_int8|undquote|combine|connect|convert|DocData|entropy|EXEC_EC|gridset|has_any|iterate|makeDir|mapping|null_dp|null_fp|null_ip|null_sp|null_up|null_wp|ordinal|overlay|polygon|replace|rlookup|RoundUp|sqrdist|strrpos|SubItem|unquote|argmax|argmin|asList|bg_xor|bitand|bitxor|bp_xor|canyon|dquote|expand|invert|IsNull|isZero|lookup|null_b|null_c|null_d|null_f|null_i|null_s|null_u|null_w|pcount|repeat|select|strlen|strpos|subset|substr|to_utf|unique|AsHex|bitor|const|count|dist2|first|get_x|get_y|index|ltrim|merge|modus|quote|range|right|Round|rtrim|union|area|atan|corr|dist|last|left|loop|mean|name|ramp|sort|sqrt|trim|add|all|and|any|cos|cov|div|exp|iif|log|max|mid|min|mod|mul|neg|not|pow|rgb|sin|sub|sum|tan|var|do|eq|ge|gt|id|le|lt|ne|or|pi|sd)\\("
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.geodms",
          "match": ":="
        },
        {
          "name": "keyword.operator.logical.geodms",
          "match": "\\|\\||&&|!"
        },
        {
          "name": "keyword.operator.arithmetic.geodms",
          "match": "\\+|-|\\*|%|\\^|#"
        },
        {
          "name": "keyword.operator.division.geodms",
          "match": "(?<=\\s)/(?!/)(?=\\s)"
        },
        {
          "name": "keyword.operator.comparison.geodms",
          "match": "<=|>=|<>|<|>|="
        },
        {
          "name": "keyword.operator.ternary.geodms",
          "match": "\\?|:"
        },
        {
          "name": "punctuation.separator.comma.geodms",
          "match": ","
        },
        {
          "name": "keyword.operator.path.geodms",
          "match": "(?<=\\b(?:for_each_[A-Za-z0-9_]*|bg_[A-Za-z0-9_]*|bp_[A-Za-z0-9_]*|cgal_[A-Za-z0-9_]*|geos_[A-Za-z0-9_]*)\\()\\s*/"
        }
      ]
    },
    "genericAngles": {
      "patterns": [
        {
          "name": "keyword.operator.bracket.geodms",
          "match": "(?<=\\b(?:Attribute|Parameter|Unit)\\s)<|>"
        }
      ]
    },
    "otherBrackets": {
      "patterns": [
        {
          "name": "keyword.operator.bracket.geodms",
          "match": "[\\[\\]{}]"
        }
      ]
    }
  }
}
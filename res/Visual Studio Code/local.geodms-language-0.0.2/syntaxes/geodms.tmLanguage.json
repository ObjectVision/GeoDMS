{
  "name": "GeoDMS",
  "scopeName": "source.geodms",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#doubleQuoted"
    },
    {
      "include": "#singleQuoted"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#declaredNames"
    },
    {
      "include": "#properties"
    },
    {
      "include": "#types"
    },
    {
      "include": "#booleans"
    },
    {
      "include": "#functionCalls"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#genericAngles"
    },
    {
      "include": "#otherBrackets"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.geodms",
          "match": "//.*$"
        },
        {
          "name": "comment.block.geodms",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "doubleQuoted": {
      "patterns": [
        {
          "name": "string.quoted.double.geodms",
          "begin": "\"",
          "end": "\""
        }
      ]
    },
    "singleQuoted": {
      "patterns": [
        {
          "name": "string.quoted.single.geodms",
          "begin": "'",
          "end": "'"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.geodms",
          "match": "\\b\\d+(?:\\.\\d+)?(?:[eE][+-]?\\d+)?\\b"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "keyword.control.declaration.primary.geodms",
          "match": "\\b(?i:Container|Template)\\b"
        },
        {
          "name": "keyword.control.declaration.secondary.geodms",
          "match": "\\b(?i:Attribute|Parameter)\\b"
        },
        {
          "name": "keyword.control.declaration.unit.geodms",
          "match": "\\b(?i:Unit)\\b"
        }
      ]
    },
    "declaredNames": {
      "patterns": [
        {
          "name": "entity.name.identifier.geodms",
          "match": "(?<=\\b(?i:Attribute)\\s*<[^>\\n]+>\\s+)[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "entity.name.identifier.geodms",
          "match": "(?<=\\b(?i:Parameter)\\s*<[^>\\n]+>\\s+)[A-Za-z_][A-Za-z0-9_]*"
        },
        {
          "name": "entity.name.identifier.geodms",
          "match": "(?<=\\b(?i:Container|Template|Unit)\\s+)[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "properties": {
      "patterns": [
        {
          "name": "support.type.property.geodms",
          "match": "\\b(?i:explicitsuppliers|storagereadonly|disablestorage|integritycheck|storagename|storagetype|dialogdata|dialogtype|sqlstring|storedata|freedata|ishidden|keepdata|nrofrows|syncmode|source|descr|label|using|expr|cdf|url)\\b(?=\\s*[:=,])"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.geodms",
          "match": "\\bFloat32Seq|Float64Seq|UInt16Seq|UInt32Seq|UInt64Seq|DPolygon|FPolygon|Int16Seq|Int32Seq|Int64Seq|IPolygon|SPolygon|UInt8Seq|UPolygon|WPolygon|Float32|Float64|Int8Seq|DPoint|FPoint|IPoint|SPoint|String|UInt16|UInt32|UInt64|UPoint|WPoint|Int16|Int32|Int64|UInt2|UInt4|UInt8|Bool|Int8|Void\\b"
        }
      ]
    },
    "booleans": {
      "patterns": [
        {
          "name": "constant.language.boolean.geodms",
          "match": "\\bfalse|False|FALSE|TRUE|true|True\\b"
        }
      ]
    },
    "functionCalls": {
      "patterns": [
        {
          "name": "entity.name.function.geodms",
          "match": "\\b(?:griddist_zonal_maximp_untiled_latitude_specific|select_uint16_with_org_rel_with_attr_by_cond|select_uint32_with_org_rel_with_attr_by_cond|select_uint64_with_org_rel_with_attr_by_cond|select_uint8_with_org_rel_with_attr_by_cond|griddist_maximp_untiled_latitude_specific|griddist_zonal_untiled_latitude_specific|griddist_zonal_maximp_latitude_specific|select_with_org_rel_with_attr_by_cond|griddist_untiled_latitude_specific|select_uint16_with_attr_by_org_rel|select_uint32_with_attr_by_org_rel|select_uint64_with_attr_by_org_rel|griddist_maximp_latitude_specific|select_uint8_with_attr_by_org_rel|griddist_zonal_latitude_specific|select_uint16_with_attr_by_cond|select_uint32_with_attr_by_cond|select_uint64_with_attr_by_cond|select_uint8_with_attr_by_cond|dyna_segment_with_ends_uint64|griddist_zonal_maximp_untiled|strongly_connected_components|ClassifyNonzeroEqualInterval|dyna_point_with_ends_uint64|geos_simplify_multi_polygon|select_with_attr_by_org_rel|ClassifyNonzeroJenksFisher|griddist_latitude_specific|select_uint16_with_org_rel|select_uint32_with_org_rel|select_uint64_with_org_rel|bg_simplify_multi_polygon|cgal_polygon_connectivity|ClassifyNonzeroEqualCount|frequency_table_with_null|geos_buffer_multi_polygon|geos_polygon_connectivity|select_uint8_with_org_rel|argmax_alldefined_uint16|argmin_alldefined_uint16|bg_buffer_single_polygon|cgal_split_union_polygon|GeoDmsMajorVersionNumber|GeoDmsMinorVersionNumber|geos_simplify_linestring|geos_split_union_polygon|join_equal_values_uint16|join_equal_values_uint32|join_equal_values_uint64|select_with_attr_by_cond|argmax_alldefined_uint8|argmax_ifdefined_uint16|argmin_alldefined_uint8|argmin_ifdefined_uint16|bg_buffer_multi_polygon|bg_outer_single_polygon|bg_polygon_connectivity|bp_buffer_multi_polygon|bp_polygon_connectivity|cgal_buffer_multi_point|collect_attr_by_org_rel|geos_buffer_multi_point|griddist_maximp_untiled|join_equal_values_uint8|join_near_values_uint16|join_near_values_uint32|join_near_valu